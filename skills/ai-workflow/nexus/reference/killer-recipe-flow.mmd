%% Title: Nexus `killer` Recipe — Single Differentiator Verdict + Conditional Flagged Implementation
%% Source: nexus/SKILL.md:161, 234-243
%% Format: Mermaid flowchart (TD)
flowchart TD
    Start([User: /nexus killer &lt;intent&gt;]):::entry

    subgraph Triangulation["Phase 1: Parallel Hub-Spoke — Cross-Engine Triangulation"]
        direction LR
        Compete["Compete<br/>[agy Search]<br/>market gap analysis<br/>(grounded current data)"]:::agy
        Flux["Flux<br/>[agy Deep Think]<br/>cross-domain reframe<br/>(divergent leaps)"]:::agy
        Plea["Plea<br/>[claude]<br/>empathy / latent needs"]:::claude
    end

    Start --> Compete
    Start --> Flux
    Start --> Plea

    subgraph Synthesis["Phase 2: Sequential Synthesis"]
        direction TB
        Spark["Spark<br/>[claude]<br/>aggregate 3 perspectives<br/>→ THE ONE killer feature<br/>(MUST be single, not list)"]:::claude
        Magi["Magi<br/>[claude]<br/>binary Go / No-Go<br/>strategic-impact tie-break"]:::claude
        Spark --> Magi
    end

    Compete --> Spark
    Flux --> Spark
    Plea --> Spark

    Verdict{"Magi verdict"}:::decision
    Magi --> Verdict
    Verdict -- "NO-GO" --> NoGoCard["Surface runner-up<br/>with 'weakest-link' annotation"]:::claude
    Verdict -- "GO (H/M/L)" --> Card

    Card["Phase 4 DELIVER Verdict Card<br/>(AskUserQuestion)<br/>• Killer feature<br/>• Engine-attributed evidence<br/>  (mark agy-Search / agy-DeepThink / claude)<br/>• Magi GO confidence H/M/L<br/>• Considered alternatives"]:::askuser
    NoGoCard --> Card

    Choice{"Ship this?"}:::decision
    Card --> Choice

    Choice -- "No" --> NoArtifact[/"DELIVER 'decided-not-to-ship'<br/>strategic record"/]:::deliver
    Choice -- "Modify" --> ModifyLoop["Capture modification<br/>(e.g. 'reframe around X')"]:::modify
    ModifyLoop -.->|"loop back<br/>(Flux re-runs)"| Compete
    ModifyLoop -.-> Flux
    ModifyLoop -.-> Plea

    subgraph Impl["Phase 5: Conditional Implementation (Yes only)"]
        direction TB
        Sherpa["Sherpa<br/>[claude]<br/>atomic decomposition"]:::claude
        UICheck{"ui_dimension<br/>!= none?"}:::decision
        Forge["Forge<br/>[codex]<br/>UI prototype validation"]:::codex
        Artisan["Artisan<br/>[codex]<br/>frontend production"]:::codex
        Builder["Builder<br/>[codex]<br/>backend / logic"]:::codex
        Radar["Radar<br/>[codex]<br/>differentiator edge cases"]:::codex
        Judge["judge<br/>[claude tri-engine]<br/>high-stakes review<br/>(codex + agy + claude)"]:::triengine
        Guardian["Guardian<br/>[claude]<br/>PR + feature-flag config<br/>+ rollout plan"]:::claude

        Sherpa --> UICheck
        UICheck -- "Yes (UI surface)" --> Forge
        UICheck -- "No" --> Builder
        Forge --> Artisan
        Artisan --> Builder
        Builder --> Radar
        Radar --> Judge
        Judge --> Guardian
    end

    Choice -- "Yes" --> Sherpa
    Guardian --> Ship[/"DELIVER:<br/>working feature + tests + PR<br/>+ feature flag + rollout plan"/]:::deliver

