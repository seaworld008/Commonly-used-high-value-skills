%% Title: Nexus `summit` Recipe — Tri-Engine Five-Team Quality Maximization
%% Source: nexus/SKILL.md:164, nexus/reference/summit-recipe.md
%% Format: Mermaid flowchart (TD)
flowchart TD
    Invoke([User: /nexus summit &lt;goal&gt;?]):::entry

    subgraph Preflight["Preflight (in Nexus main context)"]
        direction TB
        AgyCheck{"agy reachable?<br/>codex reachable?<br/>arena available?"}:::decision
        UserConfirm["👤 mandatory cost confirmation<br/>(20-50 agents, 1-2h, high cost)"]:::askuser
        AgyCheck -- "agy NG" --> AbortAgy[/"abort: use apex instead"/]:::deliver
        AgyCheck -- "OK" --> UserConfirm
        UserConfirm -- "decline" --> AbortUser[/"abort"/]:::deliver
    end

    Invoke --> AgyCheck

    subgraph Phase0["Phase 0: FRAMING (Claude only)"]
        direction TB
        P0["Nexus[classify] + accord[L0-L1]?<br/>+ sherpa[atomic decomp]<br/>→ mission_charter.yaml<br/>(goal / AC / team missions /<br/>cost_budget / risk_tier /<br/>ui_dimension)"]:::claude
    end
    UserConfirm -- "approve" --> P0

    subgraph Phase1["Phase 1: ANALYSIS Team (tri-engine parallel)"]
        direction LR
        A_Claude["Claude branch<br/>atlas + sherpa<br/>(architecture trade-off,<br/>epic decomposition)"]:::claude
        A_Codex["Codex branch<br/>lens + scout +<br/>sentinel + siege<br/>(sandbox code-analysis)"]:::codex
        A_Agy["agy branch<br/>trail + fossil + lore<br/>+ atlas + field<br/>(1M ctx + Search)"]:::agy
        A_Design["Design sub<br/>(if ui_dimension != none)<br/>echo[claude] + frame/palette[agy]"]:::design
    end
    Phase0 --> A_Claude
    Phase0 --> A_Codex
    Phase0 --> A_Agy
    Phase0 -.->|"if UI"| A_Design

    MagiSynth["magi[tri-engine arbitrate]<br/>Logos / Pathos / Sophia<br/>→ analysis_consensus.md<br/>(CONFIRMED/LIKELY/MINORITY/DISPUTED)"]:::claude
    A_Claude --> MagiSynth
    A_Codex --> MagiSynth
    A_Agy --> MagiSynth
    A_Design --> MagiSynth

    DisputeGate{"disputed/total<br/>&gt; 0.30?"}:::decision
    MagiSynth --> DisputeGate
    DisputeGate -- "Yes" --> EscalateP1["👤 user dispute review"]:::askuser
    DisputeGate -- "No" --> Phase2
    EscalateP1 --> Phase2

    subgraph Phase2["Phase 2: PLANNING (Claude opus, Plan-and-Execute)"]
        direction TB
        P2["sherpa[DAG] + magi[arbitrate]<br/>→ execution_plan.yaml<br/>(per-task engine assignment)"]:::claude
    end

    subgraph Phase3["Phase 3: DESIGN ‖ EXECUTION (parallel tracks)"]
        direction TB
        subgraph Design["Design Track (if UI) — Vision coords"]
            direction LR
            D_Claude["Claude: vision + prose + echo<br/>(direction, microcopy, persona)"]:::claude
            D_Codex["Codex: pixel + forge + flow<br/>+ funnel + vitrine"]:::codex
            D_Agy["agy: sketch + muse + frame<br/>+ palette + ink"]:::agy
        end
        subgraph Execution["Execution Track — rally[COLLABORATE]"]
            direction LR
            E_Routing["target distribution<br/>60% Codex / 25% agy / 15% Claude<br/>(builder/artisan/native/schema/bolt on codex,<br/>scribe/tome/morph on agy,<br/>sentinel/cloak/crypt on claude)"]:::triengine
        end
        FrameBridge[/"Frame bridges<br/>design → impl<br/>(tokens + component contracts)"/]:::triengine
        Design --> FrameBridge
        Execution --> FrameBridge
    end
    Phase2 --> Design
    Phase2 --> Execution

    subgraph Phase4["Phase 4: VERIFICATION (tri-engine quorum)"]
        direction LR
        V_Judge["judge<br/>(built-in tri-engine fan-out)"]:::triengine
        V_Codex["Codex dynamic<br/>radar + voyager + siege<br/>+ probe + drill<br/>+ sentinel rescan"]:::codex
        V_Agy["agy static/compliance<br/>attest + ripple + canon + oath<br/>+ rally[independent review]"]:::agy
        V_Claude["Claude UX (if UI)<br/>echo + palette"]:::claude
    end
    FrameBridge --> V_Judge
    FrameBridge --> V_Codex
    FrameBridge --> V_Agy
    FrameBridge -.->|"if UI"| V_Claude

    Quorum{{"Quorum:<br/>CONFIRMED/LIKELY<br/>× CRITICAL/HIGH?"}}:::gate
    V_Judge --> Quorum
    V_Codex --> Quorum
    V_Agy --> Quorum
    V_Claude --> Quorum

    subgraph Phase5["Phase 5: IMPROVEMENT Loop (orbit drives, max 3×)"]
        direction TB
        Orbit["orbit<br/>(loop driver + circuit breaker)"]:::subhub
        Improve["Claude: zen + sage (judgment)<br/>+ Codex: bolt/tuner/sweep/mend/schema<br/>+ agy: atlas/lore/horizon/shift<br/>+ Design: vision[claude] + palette/muse[agy]?"]:::triengine
        Arbit["magi[select improvements]<br/>→ applied_improvements.yaml"]:::claude
        Orbit --> Improve --> Arbit --> Orbit
    end

    Quorum -- "Yes (must fix)" --> Orbit
    Arbit -.->|"re-execute affected tasks"| Design
    Arbit -.-> Execution

    Breaker{"loop ≥ 3 OR<br/>Agent Tennis OR<br/>budget exceed?"}:::decision
    Orbit --> Breaker
    Breaker -- "Yes" --> CaveatDeliver["👤 escalate / deliver with caveat"]:::askuser
    Breaker -- "No (resolved or in-progress)" --> Quorum

    subgraph Phase6["Phase 6: DELIVERY (Claude)"]
        direction TB
        P6["guardian[PR-prep]<br/>+ launch[release + rollback]"]:::claude
    end
    Quorum -- "No (clean)" --> P6
    CaveatDeliver --> P6
    P6 --> Done[/"NEXUS_COMPLETE<br/>engine-attributed evidence trail<br/>+ quorum summary + loop summary"/]:::deliver

    classDef entry fill:#e8f4f8,stroke:#0b6e99,stroke-width:2px,color:#000
    classDef claude fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1.5px,color:#000
    classDef codex fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#000
    classDef agy fill:#e3f2fd,stroke:#1565c0,stroke-width:1.5px,color:#000
    classDef triengine fill:#fce4ec,stroke:#ad1457,stroke-width:2px,color:#000
    classDef subhub fill:#fce4ec,stroke:#ad1457,stroke-width:2px,color:#000
    classDef design fill:#ede7f6,stroke:#4527a0,stroke-width:1.5px,color:#000
    classDef askuser fill:#fff8e1,stroke:#f57c00,stroke-width:2px,color:#000
    classDef decision fill:#ffebee,stroke:#c62828,stroke-width:1.5px,color:#000
    classDef gate fill:#ffe0b2,stroke:#bf360c,stroke-width:3px,color:#000
    classDef deliver fill:#e0f2f1,stroke:#00695c,stroke-width:2px,color:#000
