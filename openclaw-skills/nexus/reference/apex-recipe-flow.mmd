%% Title: Nexus `apex` Recipe — Full-Cycle Auto-Implementation
%%        (Discovery → Spec → Parallel Design → Risk Gate → Loop → Ship)
%% Source: nexus/SKILL.md:158, nexus/reference/apex-recipe.md
%% Format: Mermaid flowchart (TD)
flowchart TD
    Invoke([User: /nexus apex &lt;goal&gt;? ]):::entry
    Mode{"goal supplied?"}:::decision
    Invoke --> Mode

    subgraph Phase0["Phase 0: Bootstrap (autonomous mode only)"]
        direction TB
        Scan["0a SCAN (parallel)<br/>project_scan + voice? + pulse?<br/>+ compete? + trace?"]:::claude
        SparkP0["0b spark<br/>(3-5 candidates)"]:::claude
        RankP0["0c rank ICE/RICE/WSJF<br/>+ sage? socratic check"]:::claude
        SelectP0["0d SELECT<br/>auto / magi tie-break / escalate"]:::claude
        ConfirmP0["0e 👤 boundary confirm<br/>(60s window in AUTORUN_FULL)"]:::askuser
        Scan --> SparkP0 --> RankP0 --> SelectP0 --> ConfirmP0
    end

    Mode -- "No (goal=auto)" --> Scan
    Mode -- "Yes" --> Phase1
    ConfirmP0 --> Phase1

    subgraph Phase1["Phase 1: Discovery"]
        direction TB
        P1["plea (personas 3+)<br/>+ field (BEST)<br/>+ echo? (existing product)"]:::claude
    end

    subgraph Phase2["Phase 2: Ideate"]
        direction TB
        P2["riff (diamond, ≤4 turns)"]:::claude
    end

    subgraph Phase3["Phase 3: Verdict"]
        direction TB
        P3["magi (Logos / Pathos / Sophia)<br/>→ verdict + AC seed"]:::claude
    end
    Split{"split decision<br/>(1-1-1)?"}:::decision

    subgraph Phase4["Phase 4: Spec"]
        direction TB
        P4["accord (L0→L3 traceability)<br/>+ void? (Full→YAGNI)<br/>+ scribe? (M+ → PRD/SRS)"]:::claude
    end

    Phase1 --> Phase2 --> Phase3 --> Split
    Split -- "Yes" --> HumanReview["👤 human verdict review"]:::askuser
    Split -- "No" --> Phase4
    HumanReview --> Phase4

    subgraph Phase5["Phase 5: Design + Risk Gate (parallel)"]
        direction TB
        subgraph Tech["Tech Track"]
            TechBox["atlas (ADR + dep graph)<br/>+ gateway? (API change)<br/>+ schema? (DB change)"]:::claude
        end
        subgraph UX["UX Track — Vision sub-orchestrates"]
            VisionHub["vision (direction)"]:::subhub
            UXBox["muse → [palette ‖ prose ‖ flow?]<br/>→ frame? → forge → echo"]:::claude
            VisionHub --> UXBox
        end
        RiskGate{{"★ Risk Gate (tri-axis)<br/>omen RPN=0 ∧ ripple Go/Cond-Go<br/>∧ echo Valence+a11y pass"}}:::gate
        Tech --> RiskGate
        UX --> RiskGate
    end

    Phase4 --> Tech
    Phase4 --> UX

    GateVerdict{"Risk Gate<br/>verdict"}:::decision
    RiskGate --> GateVerdict
    GateVerdict -- "No-Go" --> Phase4
    GateVerdict -- "Plea↔Echo divergence" --> Phase4
    GateVerdict -- "Go / Cond-Go" --> EngineCheck

    EngineCheck{"engine check<br/>Codex available?<br/>max_depth≥2"}:::decision
    EngineCheck -- "NG" --> RunnerErr[/"handoff_error<br/>runner_unavailable"/]:::deliver
    EngineCheck -- "OK" --> Phase6

    subgraph Phase6["Phase 6: Implementation Loop (engine = Codex CLI)"]
        direction TB
        OrbitHub["orbit (loop contract<br/>+ convergence + circuit breaker)"]:::subhub
        LoopBody["spawn_agent on Codex:<br/>builder + artisan? + vitrine?<br/>+ judge + radar + voyager?<br/>(4-8 iterations)"]:::codex
        OrbitHub --> LoopBody
        LoopBody --> OrbitHub
    end

    LoopStuck{"stuck or<br/>budget exceeded?"}:::decision
    Phase6 --> LoopStuck
    LoopStuck -- "Yes" --> EscalateLoop["close_agent + 👤 escalate"]:::askuser
    LoopStuck -- "No (converged)" --> Ship

    subgraph Ship["Ship"]
        direction TB
        ShipBox["guardian (commit/branch/PR)<br/>+ launch (release + rollback)"]:::claude
    end
    Ship --> Delivered[/"DELIVER: shipped feature<br/>+ PR + release plan + rollback"/]:::deliver

    classDef entry fill:#e8f4f8,stroke:#0b6e99,stroke-width:2px,color:#000
    classDef claude fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1.5px,color:#000
    classDef codex fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#000
    classDef subhub fill:#fce4ec,stroke:#ad1457,stroke-width:2px,color:#000
    classDef askuser fill:#fff8e1,stroke:#f57c00,stroke-width:2px,color:#000
    classDef decision fill:#ffebee,stroke:#c62828,stroke-width:1.5px,color:#000
    classDef gate fill:#ffe0b2,stroke:#bf360c,stroke-width:3px,color:#000
    classDef deliver fill:#e0f2f1,stroke:#00695c,stroke-width:2px,color:#000
