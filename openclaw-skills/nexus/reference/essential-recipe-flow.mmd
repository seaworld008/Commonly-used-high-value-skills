%% Title: Nexus `essential` Recipe — Single Must-Have Verdict + Conditional Implementation
%% Source: nexus/SKILL.md:160, 223-232
%% Format: Mermaid flowchart (TD)
flowchart TD
    Start([User: /nexus essential &lt;intent&gt;]):::entry

    subgraph Verdict["Phase 1-4: Verdict Funnel (sequential, subtraction-oriented)"]
        direction TB
        Plea["Plea<br/>[claude]<br/>pain extraction"]:::claude
        Spark["Spark<br/>[claude]<br/>feature spec"]:::claude
        Magi["Magi<br/>[claude]<br/>necessity arbitration<br/>(Sophia filters 'Should' posing as 'Must')"]:::claude
        Rank["Rank<br/>[claude]<br/>MoSCoW → single top Must-have"]:::claude
        Plea --> Spark --> Magi --> Rank
    end

    Start --> Plea

    Tie{"Tie on top<br/>Must-have?"}:::decision
    Rank --> Tie
    Tie -- "No" --> Card
    Tie -- "Yes → Sophia" --> SophiaResolve["Magi Sophia tie-break"]:::claude
    SophiaResolve --> StillTie{"Still tied?"}:::decision
    StillTie -- "No" --> Card
    StillTie -- "Yes" --> EscalateTie["Escalate tied candidates<br/>via AskUserQuestion"]:::askuser
    EscalateTie --> Card

    Card["Phase 5 DELIVER Verdict Card<br/>(AskUserQuestion)<br/>• Recommended must-have<br/>• Why (2-3 lines)<br/>• Source: Plea→Spark→Magi→Rank<br/>• Rejected alternatives"]:::askuser

    Choice{"Build this?"}:::decision
    Card --> Choice

    Choice -- "No" --> NoArtifact[/"DELIVER 'decided-not-to-build'<br/>verdict record"/]:::deliver
    Choice -- "Modify" --> ModifyLoop["Capture modification<br/>as additional constraint"]:::modify
    ModifyLoop -.->|"loop back"| Plea

    subgraph Impl["Phase 6: Conditional Implementation (Yes only)"]
        direction TB
        Sherpa["Sherpa<br/>[claude]<br/>atomic decomposition"]:::claude
        Builder["Builder<br/>[codex]<br/>code generation"]:::codex
        Radar["Radar<br/>[codex]<br/>tests / edge cases"]:::codex
        Guardian["Guardian<br/>[claude]<br/>PR prep"]:::claude
        Sherpa --> Builder --> Radar --> Guardian
    end

    Choice -- "Yes" --> Sherpa
    Guardian --> Ship[/"DELIVER:<br/>working feature + tests + PR"/]:::deliver

    classDef entry fill:#e8f4f8,stroke:#0b6e99,stroke-width:2px,color:#000
    classDef claude fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1.5px,color:#000
    classDef codex fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px,color:#000
    classDef askuser fill:#fff8e1,stroke:#f57c00,stroke-width:2px,color:#000
    classDef decision fill:#ffebee,stroke:#c62828,stroke-width:1.5px,color:#000
    classDef modify fill:#fff3e0,stroke:#ef6c00,stroke-dasharray: 4 3,color:#000
    classDef deliver fill:#e0f2f1,stroke:#00695c,stroke-width:2px,color:#000
