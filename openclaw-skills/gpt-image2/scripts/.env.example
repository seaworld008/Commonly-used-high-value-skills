# gpt-image2 skill configuration
# Optional: copy this file to .env to override the process environment.
# If GPT_IMAGE2_API_KEY is empty, the script falls back to OPENAI_API_KEY
# and CODEX_OPENAI_API_KEY when exposed to the process, then OPENAI_API_KEY
# in ~/.codex/auth.json.
# If GPT_IMAGE2_BASE_URL is empty, the script falls back to OPENAI_BASE_URL,
# OPENAI_API_BASE_URL, OPENAI_API_BASE, CODEX_OPENAI_BASE_URL,
# CODEX_OPENAI_API_BASE_URL, then the current provider base_url in
# ~/.codex/config.toml. It does not hard-code the official OpenAI endpoint.
GPT_IMAGE2_API_KEY=
GPT_IMAGE2_BASE_URL=
GPT_IMAGE2_MODEL=gpt-image-2
GPT_IMAGE2_MODE=current
GPT_IMAGE2_N=1
GPT_IMAGE2_RESOLUTION=1k
GPT_IMAGE2_ASPECT_RATIO=1:1
GPT_IMAGE2_QUALITY=
GPT_IMAGE2_OUT_DIR=./image2_output
GPT_IMAGE2_TIMEOUT_MS=240000
